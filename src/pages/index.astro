---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<div class="content">
		<h1>Welcome!</h1>
		<p class="intro">
			My name is Sara, and I am so glad you are here. Taking the next
			steps to improve your mental health often comes with doubt,
			insecurity, and fears, so the fact that you've even stumbled across
			this page means a lot. Let's get started!
		</p>
		<a class="schedule" href="/contact">
			<div class="schedule">Schedule Our First Meeting</div>
		</a>
	</div>
</Layout>

<style>
	.content {
		width: 100%;
		max-width: min(var(--small-page-width), 100%);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.intro {
		font-size: 1.2em;
		text-align: center;
	}

	a.schedule {
		text-decoration: none;
	}

	div.schedule {
		width: fit-content;
		color: var(--color-bg);
		padding: 1rem;
		background-color: var(--color-primary);
		border-radius: 1rem;
		margin: 3rem;
		font-size: 1.3em;
		font-weight: 500;
	}
</style>
